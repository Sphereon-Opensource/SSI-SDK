{
  "ICredentialDesignManager": {
    "components": {
      "schemas": {
        "IGetCredentialDesignArgs": {
          "type": "object",
          "properties": {
            "credentialDesignId": {
              "type": "string"
            }
          },
          "required": ["credentialDesignId"]
        },
        "IAddCredentialDesignArgs": {
          "type": "object",
          "properties": {}
        },
        "IUpdateCredentialDesignArgs": {
          "type": "object",
          "properties": {
            "credentialDesignId": {
              "type": "string"
            }
          },
          "required": ["credentialDesignId"]
        },
        "IRemoveCredentialDesignArgs": {
          "type": "object",
          "properties": {
            "credentialDesignId": {
              "type": "string"
            }
          },
          "required": ["credentialDesignId"]
        }
      },
      "methods": {
        "cdmGetCredentialDesigns": {
          "description": "Get all credential designs",
          "arguments": {
            "type": "object",
            "properties": {}
          },
          "returnType": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "cdmGetCredentialDesign": {
          "description": "Get a credential design by ID",
          "arguments": {
            "$ref": "#/components/schemas/IGetCredentialDesignArgs"
          },
          "returnType": {
            "type": "object"
          }
        },
        "cdmAddCredentialDesign": {
          "description": "Add a new credential design",
          "arguments": {
            "$ref": "#/components/schemas/IAddCredentialDesignArgs"
          },
          "returnType": {
            "type": "object"
          }
        },
        "cdmUpdateCredentialDesign": {
          "description": "Update an existing credential design",
          "arguments": {
            "$ref": "#/components/schemas/IUpdateCredentialDesignArgs"
          },
          "returnType": {
            "type": "object"
          }
        },
        "cdmRemoveCredentialDesign": {
          "description": "Remove a credential design by ID",
          "arguments": {
            "$ref": "#/components/schemas/IRemoveCredentialDesignArgs"
          },
          "returnType": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
